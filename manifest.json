{
    "name":"Declutter",
    "version":"0.1.0",
    "permissions":["tabs"],
    "host_permissions":["<all_urls>"],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts":[
        {
            "matches":["<all_urls>"],
            "js": ["contentScript.js"]
        }
    ],
    "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "DeClutter"
    },
    "icons": {
        "48": "icon.png",
        "128": "icon.png"
     },  
    "manifest_version": 3
}